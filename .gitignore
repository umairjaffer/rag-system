# ============================================================
# .gitignore for RAG System
# Prevents sensitive files, build artifacts, and local data
# from being committed to version control.
# ============================================================

# Environment variables (NEVER commit these)
.env

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# FAISS index files (large binary files, regenerate from PDFs)
faiss_index/

# Uploaded PDF files (user data, keep out of repo)
uploads/

# Pytest and coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Logs
*.log
logs/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json